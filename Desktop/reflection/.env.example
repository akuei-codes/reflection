# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=your-session-secret-change-in-production

# Callback URL your app will use (must be reachable by Princeton CAS)
# For local dev use something like http://localhost:5173 (frontend) and backend will use this for CAS callback
BASE_URL=http://localhost:5173
API_URL=http://localhost:3001

# OpenAI (for moderation + reflection summaries + growth insights)
OPENAI_API_KEY=sk-your-openai-api-key

# Uploads (local path for profile photos)
UPLOAD_DIR=./uploads
